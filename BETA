<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#050505">
<meta http-equiv="Cache-Control" content="no-cache,no-store,must-revalidate">
<title>IPTV NETRANGE - AO VIVO</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<style>
/* OTIMIZAÇÃO GPU EXTREMA PARA TVS ANTIGAS */
:root {
    --bg-deep: #050505; --bg-panel: #111111;
    --main-color: #FF6600; --main-color-glow: rgba(255, 102, 0, 0.4); 
    --danger-color: #FF3B30; --danger-glow: rgba(255, 59, 48, 0.3);
    --font-xs: 1.8vh; --font-sm: 2.2vh; --font-md: 3vh; --font-lg: 5vh; 
}
* { margin:0; padding:0; box-sizing:border-box; outline:none; -webkit-tap-highlight-color:transparent; -webkit-user-select:none; user-select:none; }
html, body { background:var(--bg-deep); color:#fff; font-family:'Montserrat', sans-serif; width:100%; height:100%; overscroll-behavior:none; overflow: hidden; }
.theme-text { color:var(--main-color); text-shadow: 0 0 10px rgba(255, 102, 0, 0.2); }
#splash-screen { position:fixed; top:0; left:0; width:100%; height:100%; background:var(--bg-deep); z-index:9999999; display:flex; flex-direction:column; align-items:center; justify-content:center; transform: translateZ(0); }
.splash-logo { font-size:10vh; font-weight:900; letter-spacing:2px; text-align:center; }
#splash-msg { color:var(--main-color); margin-top:20px; font-size:var(--font-sm); font-weight:700; letter-spacing:1px; white-space:pre-line; text-align:center; line-height:1.5; }
.hide { display:none!important; }
.flex-center { display:flex; align-items:center; justify-content:center; flex-direction:column; }
.layer { position:fixed; top:0; left:0; width:100%; height:100%; z-index:10; background:var(--bg-deep); overflow:hidden; transform: translateZ(0); }
button, .cat-item, .item, .key, .menu-power-btn, .power-btn, .smart-card, .toggle-btn { cursor:pointer; touch-action: manipulation; }

.focused { border: 3px solid var(--main-color)!important; box-shadow: 0 0 20px var(--main-color-glow)!important; z-index: 50; will-change: border-color, box-shadow; }
.focused svg, .focused .card-title, .focused span { color: var(--main-color)!important; text-shadow: 0 0 10px var(--main-color-glow); filter: drop-shadow(0 0 10px var(--main-color-glow)); }

#vid-box.focused { border: 3px solid var(--main-color)!important; background: transparent!important; box-shadow: inset 0 0 20px var(--main-color-glow), 0 0 20px var(--main-color-glow)!important; }
#vid-box.fs, #vid-box.fs.focused { border:none!important; width:100vw!important; height:100vh!important; z-index:999999!important; position:fixed!important; top:0!important; left:0!important; background:#000!important; display:block!important; box-shadow:none!important; }

.login-box { width:650px; max-width:90%; padding:40px; background:var(--bg-panel); border:1px solid #222; border-radius: 12px; text-align:center; box-shadow: 0 20px 50px rgba(0,0,0,0.9); }
.logo-txt { font-size:4.5vh; font-weight:900; margin-bottom:2.5vh; text-align:center; } 
.inp { width:100%; padding:16px; margin:10px 0; background:#000; border:2px solid #333; color:#fff; text-align:center; font-weight:700; font-size:16px; border-radius:6px; }
.inp.focused { background:#0a0a0a!important; }

.btn { width:100%; padding:16px; margin-top:20px; background: linear-gradient(135deg, #FF6600 0%, #CC5200 100%); color:#000; border:3px solid transparent; font-weight:900; font-size:16px; border-radius:8px; text-transform:uppercase; box-shadow: 0 4px 10px rgba(0,0,0,0.5); }
.btn.focused { background:#000!important; color:var(--main-color)!important; border:3px solid var(--main-color)!important; box-shadow: 0 0 20px var(--main-color-glow)!important; }

.menu-power-btn { width:auto; height:auto; padding:1vh; border:none; background:transparent!important; display:flex; align-items:center; justify-content:center; }
.menu-power-btn svg { font-size:4.5vh; color:#fff; transition: color 0.3s; width:1em; height:1em; }
.menu-power-btn:hover svg { color: var(--danger-color); filter: drop-shadow(0 0 10px var(--danger-glow)); }
.menu-power-btn.focused { border:none!important; background:transparent!important; box-shadow:none!important; }
.menu-power-btn.focused svg { color: var(--danger-color)!important; filter: drop-shadow(0 0 15px var(--danger-glow))!important; }

.info-row { display:flex; justify-content:space-between; padding:1.5vh 0; border-bottom:1px solid #222; font-size:var(--font-sm); color:#ccc; font-weight: 700; }

.block-panel { border: 2px solid #333; border-radius: 12px; padding: 20px; margin-top: 15px; background: #0a0a0a; text-align: left; box-shadow: inset 0 5px 15px rgba(0,0,0,0.5); }
.block-title { color: var(--main-color); font-size: 18px; margin-bottom: 20px; font-weight: 900; display:flex; align-items:center; text-shadow: 0 0 10px var(--main-color-glow); }
.block-title svg { margin-right: 10px; width:1em; height:1em; }
.block-grid { display: block; text-align: center; font-size: 0; }
.toggle-item { display: inline-flex; width: 22%; margin: 1%; padding: 14px 5px; box-sizing: border-box; background: #111; border: 2px solid #333; border-radius: 8px; color: #888; font-size: 15px; font-weight: 800; align-items: center; justify-content: center; vertical-align: top; }
.toggle-item svg { margin-right: 8px; width:1em; height:1em; }
.toggle-item.active { border-color: var(--main-color); color: #fff; background: rgba(255, 102, 0, 0.15); box-shadow: 0 0 15px var(--main-color-glow); }
.toggle-item.active svg { color: var(--main-color); }
.toggle-item.focused { border-color: #fff!important; color: #fff!important; box-shadow: 0 0 15px rgba(255,255,255,0.5)!important; background: #000; }
.toggle-item.focused svg { color: #fff!important; }

#content-layer { display:flex; width:100%; height:100%; background:var(--bg-deep); overflow:hidden; }
.col-cat { width:25%; background:var(--bg-panel); display:flex; flex-direction:column; border-right:2px solid #222; height:100%; overflow:hidden; transform: translateZ(0); }
.col-list { width:35%; background:#0a0a0a; display:flex; flex-direction:column; border-right:2px solid #222; height:100%; overflow:hidden; transform: translateZ(0); }
.col-play { flex:1; display:flex; flex-direction:column; position:relative; background:transparent; height:100%; overflow:hidden; transform: translateZ(0); }

.cat-head { padding:20px 15px; background: linear-gradient(180deg, #1a1a1a 0%, #111 100%); color:var(--main-color); border-bottom:2px solid #222; text-align:center; font-size:var(--font-md); font-weight:900; flex-shrink:0; text-shadow: 0 0 8px var(--main-color-glow); }
.cat-top-row { display:flex; align-items:center; width:100%; }
.cat-title-txt { flex:1; text-align:center; letter-spacing: 1px; }
.cat-list, .item-list { flex:1; height:100%; overflow-y:auto; overflow-x:hidden; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; touch-action: pan-y; }

.cat-item { padding:18px 20px; color:#999; font-size:var(--font-sm); font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; border:3px solid transparent; border-bottom: 1px solid #1a1a1a; will-change: border-color, background; }
.item { padding:18px 20px; color:#fff; font-size:var(--font-sm); font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; border:3px solid transparent; border-bottom: 1px solid #1a1a1a; will-change: border-color, background; }
.cat-item.active { background:#1a1a1a; color:#fff; border-left:5px solid var(--main-color); }
.item.playing { color:var(--main-color); background:#1a1a1a; border-left:5px solid var(--main-color); text-shadow: 0 0 5px var(--main-color-glow); }
.fav-icon { float:right; }

.search-area { padding:15px; background:var(--bg-panel); border-bottom:2px solid #222; flex-shrink:0; }
.inp-search { width:100%; padding:14px; background:#000; border:2px solid #333; color:#fff; font-size:var(--font-sm); font-weight:800; text-transform:uppercase; text-align:center; border-radius: 6px; }
.inp-search.focused { border-color: var(--main-color)!important; box-shadow: 0 0 15px var(--main-color-glow)!important; }

.vid-box { width:100%; height:50vh; background:#000; position:relative; border-bottom:2px solid #222; overflow:hidden; flex-shrink:0; }
#player-container { width:100%; height:100%; background:#000; position:relative; }
video { width:100%; height:100%; object-fit:fill; background:#000; position:absolute; top:0; left:0; z-index:1; }

.buffer-overlay { position:absolute; top:0; left:0; width:100%; height:100%; background:#050505; z-index:50; display:none; flex-direction:column; align-items:center; justify-content:center; }
@keyframes css-spin { to { transform: rotate(360deg); } }
.buffer-spinner { width: 8vh; height: 8vh; border: 5px solid rgba(255, 102, 0, 0.2); border-top-color: var(--main-color); border-radius: 50%; animation: css-spin 1s linear infinite; display: inline-block; }
#pause-layer { display:none; position:absolute; top:0; left:0; width:100%; height:100%; background:transparent; z-index:9000; align-items:center; justify-content:center; pointer-events:none; }
#pause-layer svg { font-size:18vh; color:#FFF!important; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.8)); width:1em; height:1em; }

.meta { padding:30px; flex:1; height:100%; overflow-y:auto; background:var(--bg-panel); display:flex; flex-direction:column; touch-action: pan-y; -webkit-overflow-scrolling: touch; }
.meta-title { font-size:var(--font-lg); color:#fff; font-weight:900; margin-bottom:1vh; line-height: 1.1; text-transform: uppercase; }
.meta-desc { font-size:var(--font-sm); color:#888; margin-bottom:1vh; font-weight: 600; line-height: 1.4; }
.keys { display:flex; justify-content:space-between; align-items:center; padding-top:2.5vh; border-top:2px solid #222; margin-top:auto; flex-shrink:0; }
.key { flex:1; margin:0 .5vw; font-size:var(--font-xs); color:#ccc; font-weight:800; background:#000; border:2px solid #333; padding:1.5vh .5vw; border-radius: 6px; display:flex; align-items:center; justify-content:center; white-space:nowrap; }
.key:first-child { margin-left:0; }
.key:last-child { margin-right:0; }
.dot { width:1.2vh; height:1.2vh; flex-shrink:0; margin-right:1.2vw; border-radius:50%; box-shadow: 0 0 5px currentColor; }

.profiles-container { display:flex; justify-content:center; flex-wrap:wrap; max-width:80vw; }
.profile-card { width:14vw; height:14vw; margin: 1vw; background:linear-gradient(180deg, #181818 0%, #0a0a0a 100%); border:3px solid #222; border-radius:16px; display:flex; flex-direction:column; align-items:center; justify-content:center; box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
.profile-card svg { font-size:6vh; color:#888; margin-bottom:1.5vh; width:1em; height:1em; }
.profile-name { font-size:2.2vh; font-weight:800; color:#ccc; }

::-webkit-scrollbar { width:5px; height:5px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:#444; border-radius:4px; }
::-webkit-scrollbar-thumb:hover { background:var(--main-color); }
</style>
</head>
<body onload="App.init()">
<audio id="n-audio" src="" preload="auto"></audio>
<div id="splash-screen">
    <div class="splash-logo"><span><span style="color:#fff">IPTV</span> <span class="theme-text">NETRANGE</span></span></div>
    <div id="splash-msg"></div>
</div>
<div id="profiles-layer" class="layer flex-center hide">
    <div class="logo-txt" style="margin-bottom:5vh;font-size:5vh"><span class="theme-text">QUEM ESTÁ ASSISTINDO?</span></div>
    <div id="profiles-list" class="profiles-container"></div>
</div>
<div id="profile-modal" class="layer flex-center hide" style="background:rgba(5,5,5,0.95);z-index:9999999">
    <div class="login-box">
        <div id="pm-name" class="theme-text" style="font-size:3.5vh;margin-bottom:2.5vh;font-weight:900;text-transform:uppercase"></div>
        <button id="pm0" class="btn focusable" onclick="App.profileAction('enter')">ENTRAR NA CONTA</button> 
        <button id="pm1" class="btn focusable" style="background: linear-gradient(135deg, #333 0%, #111 100%); color:#fff; border-color:#444;" onclick="App.profileAction('delete')">EXCLUIR PERFIL</button> 
        <button id="pm2" class="btn focusable" style="background: transparent; color:#888; border-color:#333; box-shadow:none;" onclick="App.profileAction('cancel')">CANCELAR</button>
    </div>
</div>
<div id="login-layer" class="layer flex-center hide">
    <div class="login-box">
        <div class="logo-txt"><span><span style="color:#fff">IPTV</span> <span class="theme-text">NETRANGE</span></span></div>
        <input type="text" id="i0" class="inp focusable" placeholder="DNS" autocomplete="off"> 
        <input type="text" id="i1" class="inp focusable" placeholder="USUÁRIO" autocomplete="off"> 
        <input type="password" id="i2" class="inp focusable" placeholder="SENHA" autocomplete="off"> 
        <button id="i3" class="btn focusable" onclick="App.loginManual()">ENTRAR AGORA</button>
        <div id="msg-login" style="color:var(--main-color);margin-top:20px;font-size:var(--font-sm);font-weight:800"></div>
        <button id="i4" class="btn focusable hide" style="background:transparent; border-color:#333; color:#888; margin-top:10px; box-shadow:none;" onclick="App.showProfiles()">VOLTAR</button>
    </div>
</div>

<div id="content-layer" class="layer hide">
    <div class="col-cat">
        <div class="cat-head">
            <div class="cat-top-row"><div id="cat-title-txt" class="cat-title-txt">TV AO VIVO</div></div>
            <div id="item-count" style="font-size:.7em;margin-top:5px;opacity:.7;color:#888;">...</div>
        </div>
        <div id="cat-list" class="cat-list"></div>
    </div>
    <div class="col-list">
        <div class="search-area"><input type="text" id="search" class="inp-search focusable" placeholder="BUSCAR NA CATEGORIA" autocomplete="off"></div>
        <div id="item-list" class="item-list"></div>
    </div>
    <div class="col-play">
        <div id="vid-box" class="vid-box focusable" onclick="App.handleVideoTap(event)">
            <div id="player-container"><video id="player" playsinline webkit-playsinline></video></div>
            <div id="smart-buffer" class="buffer-overlay"><div class="buffer-spinner"></div></div>
            <div id="pause-layer">
                <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
            </div>
        </div>
        <div class="meta">
            <div id="meta-title" class="meta-title">...</div>
            <div id="meta-desc" class="meta-desc"></div>
            
            <div id="quick-user-info" style="display:flex; justify-content:space-between; font-size:var(--font-sm); color:#ccc; font-weight:700; margin-top: auto; border-top: 2px solid #222; padding-top: 2.5vh;">
                <span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--main-color);width:1em;height:1em;vertical-align:-0.15em;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> <span id="q-user">...</span>
                </span>
                <span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--main-color);width:1em;height:1em;vertical-align:-0.15em;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> <span id="q-exp">...</span>
                </span>
                <span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--main-color);width:1em;height:1em;vertical-align:-0.15em;"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg> <span id="q-conn">...</span>
                </span>
            </div>

            <div class="keys" style="margin-top: 2.5vh; border-top: 2px solid #222; padding-top: 2.5vh;">
                <div class="key" id="key-fs" style="pointer-events: none;"><div class="dot" style="background-color:red; box-shadow: 0 0 8px red;"></div> TELA CHEIA</div>
                <div class="key" id="key-top" style="pointer-events: none;"><div class="dot" style="background-color:#00c851; box-shadow: 0 0 8px #00c851;"></div> TOPO</div>
                <div class="key" id="key-search" style="pointer-events: none;"><div class="dot" style="background-color:var(--main-color); box-shadow: 0 0 8px var(--main-color);"></div> BUSCAR</div>
                <div class="key focusable" id="key-menu" onclick="App.openSettings()"><div class="dot" style="background-color:#33b5e5; box-shadow: 0 0 8px #33b5e5;"></div> CONFIG.</div>
            </div>
        </div>
    </div>
</div>

<div id="settings-layer" class="layer hide" style="overflow-y: auto; text-align: center;">
    <div class="login-box" style="width:680px; padding: 30px; display:inline-block; margin: 6vh auto; text-align: left; border-radius: 16px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 12px; border-bottom: 2px solid #222; padding-bottom: 12px;">
            <div class="logo-txt" id="set-title-txt" style="margin:0; font-size: 3.5vh;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:10px;color:var(--main-color);width:1em;height:1em;vertical-align:-0.125em;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M8.5 14c1.5-1.5 4-1.5 5.5 0"></path><circle cx="12" cy="9" r="2"></circle></svg>MINHA <span class="theme-text">CONTA</span>
            </div>
            <button id="s0" class="menu-power-btn focusable" onclick="App.totalReset()" style="color:var(--danger-color)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
            </button>
        </div>
        <div class="info-row" style="padding: 1vh 0;"><span id="lbl-set-u">USUÁRIO:</span> <span id="set-user" style="color:#fff">...</span></div>
        <div class="info-row" style="padding: 1vh 0;"><span id="lbl-set-e">VENCIMENTO:</span> <span id="set-exp" style="color:#fff">...</span></div>
        <div class="info-row" style="padding: 1vh 0; border-bottom: none;"><span id="lbl-set-c">TELAS:</span> <span id="set-conn" style="color:#fff">...</span></div>
        
        <div class="block-panel" style="padding: 15px; margin-top: 5px;">
            <div class="block-title" style="font-size: 16px; margin-bottom: 12px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg> PAINEL DE BLOQUEIO INTELIGENTE
            </div>
            <div class="block-grid">
                <div id="s1" class="toggle-item focusable" onclick="App.toggleCfg('adult')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> +18</div>
                <div id="s2" class="toggle-item focusable" onclick="App.toggleCfg('h24')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> 24H</div>
                <div id="s3" class="toggle-item focusable" onclick="App.toggleCfg('k4')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> 4K</div>
                <div id="s4" class="toggle-item focusable" onclick="App.toggleCfg('h265')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> H265</div>
                <div id="s5" class="toggle-item focusable" onclick="App.toggleCfg('fhd')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> FHD</div>
                <div id="s6" class="toggle-item focusable" onclick="App.toggleCfg('hd')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> HD</div>
                <div id="s7" class="toggle-item focusable" style="width: 48%;" onclick="App.toggleCfg('sd')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg> SD</div>
            </div>
        </div>

        <div class="block-panel" style="padding: 15px; margin-top: 15px;">
            <div class="block-title" style="color:#fff; text-shadow:none; font-size: 16px; margin-bottom: 12px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--main-color);width:1em;height:1em;margin-right:10px;vertical-align:-0.125em;"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg> FORMATO DE VÍDEO (TV AO VIVO)
