    if(f.adult && (/adulto|xxx|sex|porn|\+18|teste|expirado/i.test(n))) return true;
    if(f.h24 && (/24h|24 hrs|24 horas/i.test(n))) return true;
    if(f.k4 && (/4k|uhd|2160p/i.test(n))) return true;
    if(f.h265 && (/h265|hevc|h\.265/i.test(n))) return true;
    if(f.fhd && (/fhd|1080p|1080|full\s*hd/i.test(n))) return true;
    
    if(f.hd || f.sd){
        var c = n.replace(/fhd|uhd|full\s*hd|1080p|1080/g, '');
        if(f.hd && (/hd|720p|720/i.test(c))) return true;
